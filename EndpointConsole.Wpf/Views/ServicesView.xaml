<UserControl x:Class="EndpointConsole.Wpf.Views.ServicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Command="{Binding RefreshCommand}" Content="Refresh Services" />
            <Button Margin="{DynamicResource Space.Small}"
                    Command="{Binding StartSelectedServiceCommand}"
                    Content="Start"
                    IsEnabled="{Binding SelectedService, Converter={StaticResource NullToBoolConverter}}" />
            <Button Command="{Binding StopSelectedServiceCommand}"
                    Content="Stop"
                    IsEnabled="{Binding SelectedService, Converter={StaticResource NullToBoolConverter}}" />
            <Button Margin="{DynamicResource Space.Small}"
                    Command="{Binding RestartSelectedServiceCommand}"
                    Content="Restart"
                    IsEnabled="{Binding SelectedService, Converter={StaticResource NullToBoolConverter}}" />
            <TextBlock Margin="{DynamicResource Space.Small}"
                       VerticalAlignment="Center"
                       Text="{Binding StatusMessage}"
                       Style="{DynamicResource SubtleTextStyle}" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="{DynamicResource Space.TopLarge}"
                Style="{DynamicResource CardSurfaceBorderStyle}">
            <DataGrid ItemsSource="{Binding Services}"
                      SelectedItem="{Binding SelectedService}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Service Name" Binding="{Binding ServiceName}" Width="*" />
                    <DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" Width="2*" />
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status, Converter={StaticResource ServiceStatusToTextConverter}}"
                                        Width="*" />
                    <DataGridTextColumn Header="Start Type" Binding="{Binding StartType}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
