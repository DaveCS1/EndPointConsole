<UserControl x:Class="EndpointConsole.Wpf.Views.DiagnosticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Command="{Binding RefreshDiagnosticsCommand}" Content="Refresh Diagnostics" />
            <Button Margin="{DynamicResource Space.Small}"
                    Command="{Binding CollectDiagnosticsCommand}"
                    Content="Collect Diagnostics" />
            <Button Command="{Binding CancelCollectionCommand}"
                    Content="Cancel"
                    IsEnabled="{Binding IsCollecting}" />
            <TextBlock Margin="{DynamicResource Space.Small}"
                       VerticalAlignment="Center"
                       Text="Mode:"
                       Style="{DynamicResource SubtleTextStyle}" />
            <ComboBox ItemsSource="{Binding BuildModes}"
                      SelectedItem="{Binding SelectedBuildMode}" />
            <TextBlock Margin="{DynamicResource Space.Small}"
                       VerticalAlignment="Center"
                       Text="{Binding OperationStatus}"
                       Style="{DynamicResource SubtleTextStyle}" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="{DynamicResource Space.TopSmall}"
                Padding="{DynamicResource Space.Medium}"
                Style="{DynamicResource CardSurfaceBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ProgressBar Grid.Row="0"
                             Minimum="0"
                             Maximum="100"
                             IsIndeterminate="{Binding IsCollectionProgressIndeterminate}"
                             Value="{Binding CollectionProgress}" />
                <TextBlock Grid.Row="1"
                           Margin="{DynamicResource Space.TopSmall}"
                           Text="{Binding LatestBundlePath}"
                           TextWrapping="Wrap"
                           Style="{DynamicResource SubtleTextStyle}" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="{DynamicResource Space.TopSmall}"
                Padding="{DynamicResource Space.Medium}"
                Style="{DynamicResource CardSurfaceBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Text="{Binding RegistryKeyPath, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Grid.Column="2"
                         Margin="{DynamicResource Space.Small}"
                         Text="{Binding RegistryValueName, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Grid.Column="3"
                         Margin="{DynamicResource Space.Small}"
                         Text="{Binding RegistryValueData, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="4" Command="{Binding SaveRegistryValueCommand}" Content="Save Value" />
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="{DynamicResource Space.TopLarge}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="{DynamicResource Space.Small}"
                    Style="{DynamicResource CardSurfaceBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Event Log Issues" Style="{DynamicResource SectionTitleTextStyle}" />
                    <DataGrid Grid.Row="1"
                              Margin="{DynamicResource Space.TopSmall}"
                              ItemsSource="{Binding RecentEvents}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time (UTC)" Binding="{Binding TimestampUtc}" Width="*" />
                            <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="*" />
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="*" />
                            <DataGridTextColumn Header="Event Id" Binding="{Binding EventId}" Width="*" />
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="{DynamicResource Space.Small}"
                    Style="{DynamicResource CardSurfaceBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Registry Values" Style="{DynamicResource SectionTitleTextStyle}" />
                    <DataGrid Grid.Row="1"
                              Margin="{DynamicResource Space.TopSmall}"
                              ItemsSource="{Binding RegistryValues}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2"
                            Margin="{DynamicResource Space.TopSmall}"
                            Padding="{DynamicResource Space.Small}"
                            Style="{DynamicResource ContentSurfaceBorderStyle}"
                            Visibility="{Binding OperationSeverity, Converter={StaticResource SeverityToVisibilityConverter}, ConverterParameter=Warning}">
                        <TextBlock Text="{Binding SeverityMessage}" Style="{DynamicResource SubtleTextStyle}" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
