<UserControl x:Class="EndpointConsole.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Command="{Binding RefreshCommand}" Content="Refresh Snapshot" />
            <TextBlock Margin="{DynamicResource Space.Small}"
                       VerticalAlignment="Center"
                       Text="{Binding LastUpdatedSummary}"
                       Style="{DynamicResource SubtleTextStyle}" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="{DynamicResource Space.TopLarge}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Margin="{DynamicResource Space.Small}"
                    Style="{DynamicResource CardSurfaceBorderStyle}">
                <StackPanel>
                    <TextBlock Text="OS" Style="{DynamicResource SubtleTextStyle}" />
                    <TextBlock Margin="{DynamicResource Space.TopSmall}"
                               Text="{Binding OsSummary}"
                               TextWrapping="Wrap"
                               Style="{DynamicResource MetricTextStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="1"
                    Margin="{DynamicResource Space.Small}"
                    Style="{DynamicResource CardSurfaceBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Uptime" Style="{DynamicResource SubtleTextStyle}" />
                    <TextBlock Margin="{DynamicResource Space.TopSmall}"
                               Text="{Binding UptimeSummary}"
                               Style="{DynamicResource MetricTextStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="2"
                    Margin="{DynamicResource Space.Small}"
                    Style="{DynamicResource CardSurfaceBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Sessions" Style="{DynamicResource SubtleTextStyle}" />
                    <TextBlock Margin="{DynamicResource Space.TopSmall}"
                               Text="{Binding ActiveSessionsSummary}"
                               Style="{DynamicResource MetricTextStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="3"
                    Margin="{DynamicResource Space.Small}"
                    Style="{DynamicResource CardSurfaceBorderStyle}">
                <StackPanel>
                    <TextBlock Text="System Drive" Style="{DynamicResource SubtleTextStyle}" />
                    <TextBlock Margin="{DynamicResource Space.TopSmall}"
                               Text="{Binding DiskSummary}"
                               Style="{DynamicResource MetricTextStyle}" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Grid.ColumnSpan="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="{DynamicResource Space.Small}"
                        Style="{DynamicResource CardSurfaceBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Interactive Sessions" Style="{DynamicResource SectionTitleTextStyle}" />

                        <DataGrid Grid.Row="1"
                                  Margin="{DynamicResource Space.TopSmall}"
                                  ItemsSource="{Binding Sessions}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Session Id" Binding="{Binding SessionId}" Width="*" />
                                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="*" />
                                <DataGridTextColumn Header="User" Binding="{Binding UserName}" Width="*" />
                                <DataGridTextColumn Header="Domain" Binding="{Binding Domain}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Margin="{DynamicResource Space.Small}"
                        Style="{DynamicResource CardSurfaceBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Permission Issues" Style="{DynamicResource SectionTitleTextStyle}" />

                        <DataGrid Grid.Row="1"
                                  Margin="{DynamicResource Space.TopSmall}"
                                  ItemsSource="{Binding AclIssues}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="2*" />
                                <DataGridTextColumn Header="Identity" Binding="{Binding Identity}" Width="*" />
                                <DataGridTextColumn Header="Rights" Binding="{Binding Rights}" Width="*" />
                                <DataGridTextColumn Header="Issue" Binding="{Binding Issue}" Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
