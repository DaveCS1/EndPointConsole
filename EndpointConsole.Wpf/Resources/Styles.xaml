<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="Brush.AppBackground" Color="#FFF7F7F7" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFE2E2E2" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FF222222" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="#FF666666" />
    <SolidColorBrush x:Key="Brush.Selection" Color="#FFEFF2F5" />
    <SolidColorBrush x:Key="Brush.Hover" Color="#FFF4F6F8" />

    <Thickness x:Key="Space.Small">8</Thickness>
    <Thickness x:Key="Space.Medium">16</Thickness>
    <Thickness x:Key="Space.TopSmall">0,8,0,0</Thickness>
    <Thickness x:Key="Space.TopLarge">0,24,0,0</Thickness>

    <CornerRadius x:Key="Radius.Default">4</CornerRadius>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource Brush.AppBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    </Style>

    <Style x:Key="SidebarSurfaceBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource Radius.Default}" />
    </Style>

    <Style x:Key="HeaderSurfaceBorderStyle" TargetType="Border" BasedOn="{StaticResource SidebarSurfaceBorderStyle}" />

    <Style x:Key="ContentSurfaceBorderStyle" TargetType="Border" BasedOn="{StaticResource SidebarSurfaceBorderStyle}" />

    <Style x:Key="CardSurfaceBorderStyle" TargetType="Border" BasedOn="{StaticResource SidebarSurfaceBorderStyle}">
        <Setter Property="Padding" Value="{DynamicResource Space.Medium}" />
    </Style>

    <Style x:Key="HeadingTextStyle" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SubtleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
    </Style>

    <Style x:Key="MetricTextStyle" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="NavigationListStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Margin" Value="{DynamicResource Space.TopSmall}" />
        <Setter Property="Padding" Value="{DynamicResource Space.Medium}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="ItemSurface"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource Radius.Default}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemSurface" Property="Background" Value="{DynamicResource Brush.Hover}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemSurface" Property="Background" Value="{DynamicResource Brush.Selection}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Padding" Value="{DynamicResource Space.Small}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
    </Style>
</ResourceDictionary>
