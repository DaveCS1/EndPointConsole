<Window x:Class="EndpointConsole.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Title}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="5*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="{DynamicResource Space.Small}"
                Padding="{DynamicResource Space.Medium}"
                Style="{DynamicResource SidebarSurfaceBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="EndpointConsole" Style="{DynamicResource HeadingTextStyle}" />
                    <TextBlock Text="Windows diagnostics sample"
                               Margin="{DynamicResource Space.TopSmall}"
                               Style="{DynamicResource SubtleTextStyle}" />
                </StackPanel>

                <ListBox Grid.Row="1"
                         Margin="{DynamicResource Space.TopLarge}"
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem}"
                         Style="{DynamicResource NavigationListStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Description}" Style="{DynamicResource SubtleTextStyle}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="{DynamicResource Space.Small}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="{DynamicResource Space.Medium}"
                    Style="{DynamicResource HeaderSurfaceBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding SelectedNavigationItem.DisplayName}"
                               Style="{DynamicResource SectionTitleTextStyle}" />
                    <TextBlock Grid.Row="1"
                               Margin="{DynamicResource Space.TopSmall}"
                               Text="{Binding SelectedNavigationItem.Description}"
                               Style="{DynamicResource SubtleTextStyle}" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="{DynamicResource Space.TopSmall}"
                    Padding="{DynamicResource Space.Medium}"
                    Style="{DynamicResource ContentSurfaceBorderStyle}">
                <ContentControl Content="{Binding CurrentPageViewModel}" />
            </Border>
        </Grid>
    </Grid>
</Window>
